    "28": {
      "title": "OpenAI Closes in on $100 Billion, OpenClaw Acquired, AI Productivity Question — With Aaron Levie",
      "source": "Big Technology Podcast",
      "host": "Alex Kantrowitz",
      "participants": "Aaron Levie (Box CEO)",
      "date": "21 February 2026",
      "dateProcessed": "21 February 2026",
      "session": 6,
      "tier": 1,
      "status": "active",
      "themes": [],
      "summary": "Levie makes the sharpest articulation of why AI productivity shows up in engineering first: code is text-only, codebases contain their own context, developers are more technical and early-adopting. Box engineers estimate 5x faster builds but don't charge more - gains absorbed by competitive pressure and packed into existing licences. KPMG auditor asked to lower fees because of AI - early signal of fee pressure rippling through professional services. Box building platform layer for agents needing file systems. Amazon outage caused by agent deleting code to 'fix' a problem - the blast radius problem. Library update from two weeks to 10 minutes, but 'are we spending any less time building software? No.'",
      "keyThemes": "Coding vs knowledge work adoption gap, Productivity invisibility (priced-in gains), API-first software, Agent blast radius, Workload expansion not reduction",
      "postPotential": "high",
      "postPotentialReasoning": "",
      "_reconstructed": false,
      "url": "https://podcasts.apple.com/us/podcast/openai-closes-in-on-%24100-billion-openclaw-acquired/id1522960417?i=1000750724515"
    },
