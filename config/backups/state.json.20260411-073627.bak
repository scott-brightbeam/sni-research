    "175": {
      "title": "Are We Screwed If AI Works? — The Labour Shock Thesis",
      "source": "Big Technology Podcast",
      "host": "Alex Kantrowitz",
      "participants": "Andrew Ross Sorkin",
      "filename": "2026-03-18-big-technology-podcast-are-we-screwed-if-ai-works-with-andrew-ross-sorkin.md",
      "url": "https://www.podbean.com/ew/dir-wk4vx-2c0c8512",
      "date": "2026-03-18",
      "dateProcessed": "2026-03-24",
      "session": 34,
      "tier": 1,
      "status": "active",
      "themes": [
        "T07",
        "T10",
        "T23",
        "T27",
        "T28"
      ],
      "summary": "Sorkin argues AI's real macro risk isn't a speculative bubble but a labour shock — $700bn in capex only pays off through productivity gains that eliminate roles. His 1929 parallel isn't the market crash itself but the path to 25% unemployment. Kantrowitz pushes back with the production-boom thesis: capability expansion creates economic activity we can't yet see. The tension between these two positions — displacement vs. expansion — maps directly onto how enterprises should frame their AI strategy.",
      "keyThemes": "Labour shock vs production boom, $700bn capex bet, software sector hollowing, private credit as systemic risk, wealth concentration through AI productivity",
      "postPotential": "high",
      "postPotentialReasoning": "Sorkin's framing inverts the standard AI narrative — success is the risk, not failure. His contract-with-ChatGPT anecdote is a concrete, relatable example of displacement. The Kantrowitz counter-argument (Claude Code creating new economic activity) gives a genuine two-sided tension.",
      "_reconstructed": false
    },
    "176": {
      "title": "Inside Palantir: The Ontology Thesis and Why Data Infrastructure Outlasts Models",
      "source": "The a16z Show",
      "host": "Martin Casado, Katherine Boyle",
      "participants": "Shyam Sankar (COO, Palantir)",
      "filename": "2026-03-20-a16z-inside-palantir-building-software-that-matters-with-shyam.md",
      "url": "https://a16z.simplecast.com/episodes/inside-palantir-building-software-that-matters-with-shyam-sankar-mSRYC1eQ",
      "date": "2026-03-20",
