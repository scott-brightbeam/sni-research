        },
        {
          "session": 11,
          "source": "AI Daily Brief Coolest Agents (14 March)",
          "content": "Whittemore's 16-agent inventory confirms 'massive shift over the last 3–4 months' in agent building.",
          "url": "https://podcasters.spotify.com/pod/show/nlw/episodes/The-Coolest-Agents-Ive-Built-So-Far-e3geoup"
