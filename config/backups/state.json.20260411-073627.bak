    "69": {
      "title": "Intentional",
      "source": "Cognitive Revolution (Nathan Labenz)",
      "host": null,
      "participants": "Dan Balsam, Tom McGrath (Goodfire)",
      "date": "5 March 2026",
      "dateProcessed": "11 March 2026",
      "session": 11,
      "tier": 1,
      "status": "active",
      "themes": [
        "T08",
        "T25"
      ],
      "summary": "Goodfire ($150M Series B, $1.25B valuation, <2 years old) announces 'Intentional Design' — shaping the loss landscape to control what models learn, rather than only reverse-engineering trained models. Key technique: hallucination reduction probe trained on a frozen copy of the model to prevent the model learning to evade detection rather than genuinely reducing hallucinations. McGrath's principle: 'Don't fight backpropagation — shape the loss landscape so the model naturally wants to learn what we need.' Striking finding: removing memorisation weights from a model can *improve* reasoning performance. Real-world application: Alzheimer's prediction model revealed to be using cell-free DNA fragment length as proxy — interpretability surfaced this latent mechanism. Connects to T08 (verification as trust infrastructure) and proposed T25 (AI safety as governance mechanism).",
      "keyThemes": "Mechanistic interpretability, intentional AI design, hallucination reduction, sparse autoencoders, AI safety research, loss landscape shaping",
      "postPotential": "high",
      "postPotentialReasoning": "",
      "_reconstructed": false,
      "url": "https://www.cognitiverevolution.ai/don-t-fight-backprop-goodfire-s-vision-for-intentional-design-w-dan-balsam-tom-mcgrath/"
    },
