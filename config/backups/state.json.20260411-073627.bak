    "T04": {
      "name": "Agentic Engineering as New Professional Skill",
      "created": "Session 14",
      "lastUpdated": "Session 47",
      "documentCount": 20,
      "evidence": [
        {
          "session": 15,
          "source": "Mollick 'stop prompting start managing' (One Useful Thing, Feb 2026)",
          "content": "Give AI an SOP rather than questions. Manage rather than prompt.",
