    "167": {
      "title": "AI Scouting Report: the Good, Bad, & Weird @ Law & AI Certificate Program",
      "source": "Cognitive Revolution",
      "host": "Nathan Labenz",
      "participants": "UC Law San Francisco LexLab programme participants",
