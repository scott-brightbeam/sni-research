    "201": {
      "title": "Scaling Intelligence Out: Cisco's Internet of Cognition and the Case for Distributed AI",
      "source": "Cognitive Revolution",
      "host": "Nathan Labenz",
      "participants": "Vijoy Pandey (SVP & GM, Outshift by Cisco)",
      "filename": "2026-03-25-cognitive-revolution-scaling-intelligence-out-cisco-s-vision-for-the-internet-of.md",
      "url": "https://www.cognitiverevolution.ai/scaling-intelligence-out-cisco-s-vision-for-the-internet-of-cognition-with-vijoy-pandey/",
