    "193": {
      "title": "AI Just Gave You Superpowers — Now What?",
      "source": "a16z Podcast",
      "host": "Robert Hackett",
      "participants": "Christian Catalini (Lightspark co-founder, MIT Cryptoeconomics Lab founder), Eddie Lazarin (a16z CTO)",
      "filename": "2026-03-19-a16z-ai-just-gave-you-superpowers-now-what.md",
      "url": "https://a16z.simplecast.com/episodes/ai-just-gave-you-superpowers-now-what-w1BZEEnu",
      "date": "19 March 2026",
      "dateProcessed": "2026-03-25",
      "session": 34,
      "tier": 1,
      "status": "active",
      "themes": [
        "T03",
        "T05",
        "T10",
        "T14",
        "T21",
        "T23",
        "T24",
        "T26",
        "T33",
        "T36",
        "T37"
      ],
      "summary": "Catalini's 'Simple Economics of AGI' paper (100+ pages) is explored through dialogue with a16z CTO Lazarin. Core thesis: automation costs are falling faster than verification costs, creating a structural gap where human economic value concentrates. Three durable labour categories: directors (set intent and steer), verifiers (validate AI output, subject to the codifier's curse), and meaning makers (consensus in non-measurable domains). Two economic trajectories are mapped — hollow (junior pipeline collapses, systemic technical debt accumulates, LTCM-style failure risk) or augmented (AI accelerates mastery, directors emerge, verification infrastructure built). Crypto and blockchain framed as verification infrastructure for the agent economy.",
      "keyThemes": "Automation-verification cost gap, codifier's curse, AI sandwich org structure, hollow vs augmented economy, director/verifier/meaning-maker taxonomy, verification-grade network effects, December 2025 inflection, crypto as trust infrastructure",
      "postPotential": "high",
      "postPotentialReasoning": "Catalini's paper provides a rare formal economic framework for the AI labour discussion. The codifier's curse is a named, memorable phenomenon directly applicable to Brightbeam's enterprise clients. The AI sandwich is actionable. All senior leaders in regulated industries face the director/verifier question today."
    },
    "194": {
      "title": "The Missing Power Layer: How Commercial EV Technology Solves the Military Energy Crisis",
      "source": "The a16z Show",
      "host": "Katherine Boyle",
      "participants": "Adam Maier (CEO, Chariot Defense)",
      "filename": "2026-03-24-a16z-the-missing-power-layer-of-modern-warfare.md",
      "url": "https://a16z.simplecast.com/episodes/the-missing-power-layer-of-modern-warfare-tbo9oBnG",
