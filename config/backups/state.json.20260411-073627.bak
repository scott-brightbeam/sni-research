    "207": {
      "title": "The SpaceX and Tesla Playbook for Hard Tech Startups",
      "source": "a16z Podcast",
      "host": "Aaron Price Wright",
      "participants": "Chandler Lujiza (CEO, Galadite), Turner Caldwell (CEO, Mariana Minerals)",
      "filename": "2026-03-27-a16z-the-spacex-and-tesla-playbook-for-hard-tech-startups.md",
      "url": "https://a16z.simplecast.com/episodes/the-spacex-and-tesla-playbook-for-hard-tech-startups-1wPtKHVt",
