#!/usr/bin/env bash
# pre-push — auto-deploy to Fly when pushing to master.
#
# Git invokes this hook with one line per ref being pushed on stdin:
#   <local-ref> <local-sha> <remote-ref> <remote-sha>
# plus `$1` = remote name and `$2` = remote URL.
#
# We only deploy when:
#   - the ref is master (or main)
#   - it's not a delete (local-sha is not all zeros)
#   - the push introduces new commits (local-sha != remote-sha)
#
# If `fly deploy` fails, we exit non-zero so git aborts the push. That
# keeps GitHub and Fly in lock-step: either both update or neither does.
#
# To enable locally:    git config core.hooksPath scripts/git-hooks
# To skip a single push: git push --no-verify

set -e

z40="0000000000000000000000000000000000000000"
deploy_needed=0

while read -r local_ref local_sha remote_ref remote_sha; do
    case "$local_ref" in
        refs/heads/master|refs/heads/main)
            [ "$local_sha" = "$z40" ] && continue
            [ "$local_sha" = "$remote_sha" ] && continue
            deploy_needed=1
            ;;
    esac
done

if [ "$deploy_needed" -eq 0 ]; then
    exit 0
fi

if ! command -v fly >/dev/null 2>&1; then
    echo "[pre-push] 'fly' CLI not found on PATH — cannot deploy."
    echo "[pre-push] Install flyctl or push with --no-verify to skip this hook."
    exit 1
fi

echo "[pre-push] Pushing to master — deploying to Fly first..."
echo "[pre-push] (working directory checkout is what will be built)"
echo

if ! fly deploy --remote-only; then
    echo
    echo "[pre-push] Fly deploy FAILED — aborting push to keep origin and Fly in sync."
    echo "[pre-push] Fix the deploy issue, or pass --no-verify to push anyway."
    exit 1
fi

echo
echo "[pre-push] Fly deploy succeeded — proceeding with push."
exit 0
